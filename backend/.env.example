# --- API keys (leave blank while GEO_TEST_MODE=true) ---
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# --- Database ---
DATABASE_URL=sqlite:///./geo.db

# --- Test mode ---
# When true: template-based prompt generation + mock provider adapters.
# No real LLM API calls are made, so development incurs no 3rd-party cost.
GEO_TEST_MODE=true

# --- Provider models (optional; defaults used if unset) ---
# Search simulation (services 2 & 3): cost/quality balanced models.
SEARCH_MODEL_OPENAI=gpt-4o
SEARCH_MODEL_GEMINI=gemini-2.0-flash
SEARCH_MODEL_ANTHROPIC=claude-sonnet-4-6
# Internal generation (services 1 & 4): stronger model.
GEN_MODEL_ANTHROPIC=claude-opus-4-8

# --- Scale (reduce for cheap dev runs) ---
KEYWORD_COUNT=100
QUESTION_COUNT=100
PROVIDER_CONCURRENCY=5
SEARCH_REPEATS=10
MAX_RETRIES=3
